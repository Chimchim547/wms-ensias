<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Plan Entrepôt</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .entrepot {
            background: #f0f0f0;
            border: 3px solid #333;
            border-radius: 12px;
            padding: 20px;
            min-height: 500px;
        }
        .zone-box {
            border: 3px solid;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            position: relative;
        }
        .zone-header {
            font-weight: bold;
            font-size: 1.1em;
            padding: 5px 12px;
            border-radius: 5px;
            color: white;
            display: inline-block;
            margin-bottom: 10px;
        }
        .zone-info {
            font-size: 0.85em;
            color: #666;
            margin-bottom: 10px;
        }
        .zone-type {
            position: absolute;
            top: 10px;
            right: 15px;
            font-size: 0.8em;
            padding: 2px 8px;
            border-radius: 3px;
            color: white;
        }
        .type-stockage { background: #3498db; }
        .type-reception { background: #e67e22; }
        .type-expedition { background: #9b59b6; }
        .emplacements-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .emplacement-box {
            border: 2px solid;
            border-radius: 6px;
            padding: 10px;
            min-width: 120px;
            text-align: center;
            font-size: 0.85em;
            transition: transform 0.2s;
        }
        .emplacement-box:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        .libre {
            background: #d4edda;
            border-color: #28a745;
        }
        .libre .status-dot {
            color: #28a745;
        }
        .occupe {
            background: #f8d7da;
            border-color: #dc3545;
        }
        .occupe .status-dot {
            color: #dc3545;
        }
        .legende {
            display: flex;
            gap: 20px;
            align-items: center;
            padding: 10px 15px;
            background: white;
            border-radius: 8px;
            border: 1px solid #ddd;
        }
        .legende-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.9em;
        }
        .legende-color {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            border: 1px solid #ccc;
        }
        .stats-bar {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }
        .stat-item {
            background: white;
            border-radius: 8px;
            padding: 10px 20px;
            border: 1px solid #ddd;
            text-align: center;
        }
        .stat-number {
            font-size: 1.5em;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Plan Visuel de l'Entrepôt</h2>

        <div class="stats-bar mt-3">
            <div class="stat-item">
                <div class="stat-number text-primary"><%= zones.length %></div>
                <div>Zones</div>
            </div>
            <div class="stat-item">
                <% let totalEmp = 0; let totalLibre = 0; let totalOccupe = 0; %>
                <% zones.forEach(z => { z.emplacements.forEach(e => { totalEmp++; if(e.articles.length > 0) totalOccupe++; else totalLibre++; }); }); %>
                <div class="stat-number"><%= totalEmp %></div>
                <div>Emplacements</div>
            </div>
            <div class="stat-item">
                <div class="stat-number text-success"><%= totalLibre %></div>
                <div>Libres</div>
            </div>
            <div class="stat-item">
                <div class="stat-number text-danger"><%= totalOccupe %></div>
                <div>Occupés</div>
            </div>
            <div class="stat-item">
                <div class="stat-number text-info"><%= totalEmp > 0 ? Math.round((totalOccupe/totalEmp)*100) : 0 %>%</div>
                <div>Taux occupation</div>
            </div>
        </div>

        <div class="entrepot">
            <h5 class="text-center text-muted mb-3">ENTREPÔT WMS ENSIAS</h5>
            <div class="row">
                <% zones.forEach(z => { %>
                <div class="col-md-6 mb-3">
                    <div class="zone-box" style="border-color: <%= z.couleur %>; background: <%= z.couleur %>15;">
                        <span class="zone-type type-<%= z.type %>"><%= z.type.toUpperCase() %></span>
                        <div class="zone-header" style="background: <%= z.couleur %>;">
                            <%= z.code %>
                        </div>
                        <div class="zone-info">
                            Dimensions max: <%= z.dimensionMaxLongueur %> x <%= z.dimensionMaxLargeur %> x <%= z.dimensionMaxHauteur %> cm | Poids max: <%= z.poidsMax %> kg
                        </div>
                        <div class="emplacements-grid">
                            <% z.emplacements.forEach(e => { %>
                            <div class="emplacement-box <%= e.articles.length > 0 ? 'occupe' : 'libre' %>">
                                <strong><%= e.code %></strong><br>
                                <span class="status-dot"><%= e.articles.length > 0 ? '●' : '○' %></span>
                                <span><%= e.articles.length > 0 ? 'PLEIN' : 'LIBRE' %></span><br>
                                <small><%= e.longueur %>x<%= e.largeur %>x<%= e.hauteur %> cm</small><br>
                                <small>Max: <%= e.poidsMax %> kg</small>
                                <% if (e.articles.length > 0) { %>
                                    <hr style="margin:4px 0;">
                                    <% e.articles.forEach(a => { %>
                                        <small class="text-danger"><strong><%= a.reference %></strong></small><br>
                                        <small><%= a.designation %></small><br>
                                    <% }) %>
                                <% } %>
                            </div>
                            <% }) %>
                            <% if (z.emplacements.length === 0) { %>
                                <p class="text-muted fst-italic">Aucun emplacement dans cette zone</p>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }) %>
                <% if (zones.length === 0) { %>
                    <div class="col-12 text-center">
                        <p class="text-muted">Aucune zone créée. <a href="/zones/create">Créer une zone</a></p>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="legende mt-3">
            <strong>Légende :</strong>
            <div class="legende-item">
                <div class="legende-color" style="background: #d4edda; border-color: #28a745;"></div>
                <span>○ Libre</span>
            </div>
            <div class="legende-item">
                <div class="legende-color" style="background: #f8d7da; border-color: #dc3545;"></div>
                <span>● Plein</span>
            </div>
            <div class="legende-item">
                <div class="legende-color type-stockage"></div>
                <span>Stockage</span>
            </div>
            <div class="legende-item">
                <div class="legende-color type-reception"></div>
                <span>Réception</span>
            </div>
            <div class="legende-item">
                <div class="legende-color type-expedition"></div>
                <span>Expédition</span>
            </div>
        </div>

        <div class="mt-3">
            <a href="/zones" class="btn btn-success">Gérer les zones</a>
            <a href="/emplacements" class="btn btn-outline-success">Gérer les emplacements</a>
            <a href="/dashboard" class="btn btn-secondary">Retour</a>
        </div>
    </div>
</body>
</html>