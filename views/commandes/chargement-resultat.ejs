<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Résultat Chargement</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>🚚 Camion Expédié avec Succès !</h2>
        
        <div class="alert alert-success">
            <strong><%= chargement.commandesLivraison.length %> commande(s) expédiées</strong> en mode <strong><%= chargement.mode %></strong>.
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card border-primary mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">1. Ordre de Chargement (dans le camion)</h5>
                    </div>
                    <div class="card-body">
                        <% if (chargement.mode === 'LIFO') { %>
                        <p class="text-muted">LIFO : Le premier chargé sera le dernier livré (fond du camion).</p>
                        <% } else { %>
                        <p class="text-muted">FIFO : Le premier chargé sera le premier livré.</p>
                        <% } %>
                        <table class="table table-sm">
                            <thead><tr><th>Charger</th><th>Commande</th><th>Client</th><th>Adresse</th></tr></thead>
                            <tbody>
                                <% chargement.commandesChargement.forEach(c => { %>
                                <tr>
                                    <td><span class="badge bg-primary"><%= c.ordre %></span></td>
                                    <td><strong><%= c.numero %></strong></td>
                                    <td><%= c.client %></td>
                                    <td><%= c.adresse %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-success mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">2. Ordre de Livraison (sur la route)</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Le livreur suit cet ordre pour décharger les commandes.</p>
                        <table class="table table-sm">
                            <thead><tr><th>Livrer</th><th>Commande</th><th>Client</th><th>Adresse</th><th>Total</th></tr></thead>
                            <tbody>
                                <% chargement.commandesLivraison.forEach(c => { %>
                                <tr>
                                    <td><span class="badge bg-success"><%= c.ordre %></span></td>
                                    <td><strong><%= c.numero %></strong></td>
                                    <td><%= c.client %></td>
                                    <td><%= c.adresse %></td>
                                    <td><%= c.prixTotal.toFixed(2) %> DH</td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a href="/commandes/chargement-pdf" class="btn btn-outline-danger btn-lg">📄 Télécharger PDF Chargement</a>
            <a href="/commandes" class="btn btn-secondary">Retour aux commandes</a>
        </div>
    </div>
</body>
</html>