<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Suivi Affectations</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Suivi des Mises en Stock</h2>
        <p class="text-muted">Historique de toutes les affectations assignées aux magasiniers.</p>

        <% const enCours = missions.filter(m => m.statut === 'EN_COURS'); %>
        <% const terminees = missions.filter(m => m.statut === 'TERMINE'); %>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-primary"><%= missions.length %></h3>
                        <small>Total missions</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-warning"><%= enCours.length %></h3>
                        <small>En cours</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-success"><%= terminees.length %></h3>
                        <small>Terminées</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3><%= missions.length > 0 ? Math.round(terminees.length / missions.length * 100) : 0 %>%</h3>
                        <small>Taux réalisation</small>
                    </div>
                </div>
            </div>
        </div>

        <% if (enCours.length > 0) { %>
        <h5>En cours (<%= enCours.length %>)</h5>
        <table class="table table-striped mb-4">
            <thead class="table-dark">
                <tr>
                    <th>N°</th>
                    <th>Article</th>
                    <th>Quantité</th>
                    <th>Destination</th>
                    <th>Zone</th>
                    <th>Magasinier</th>
                    <th>Assignée le</th>
                </tr>
            </thead>
            <tbody>
                <% enCours.forEach(m => { %>
                <tr class="table-warning">
                    <td>AFF-<%= m.id %></td>
                    <td><%= m.article.reference %> - <%= m.article.designation %></td>
                    <td><strong><%= m.quantite %></strong></td>
                    <td><span class="badge bg-primary"><%= m.emplacement.code %></span></td>
                    <td><%= m.emplacement.zone.code %></td>
                    <td><%= m.magasinier.prenom %> <%= m.magasinier.nom %></td>
                    <td><%= m.dateCreation.toLocaleDateString('fr-FR') %> <%= m.dateCreation.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}) %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>

        <% if (terminees.length > 0) { %>
        <h5>Terminées (<%= terminees.length %>)</h5>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>N°</th>
                    <th>Article</th>
                    <th>Quantité</th>
                    <th>Destination</th>
                    <th>Zone</th>
                    <th>Magasinier</th>
                    <th>Assignée le</th>
                    <th>Validée le</th>
                    <th>PDF</th>
                </tr>
            </thead>
            <tbody>
                <% terminees.forEach(m => { %>
                <tr>
                    <td>AFF-<%= m.id %></td>
                    <td><%= m.article.reference %> - <%= m.article.designation %></td>
                    <td><%= m.quantite %></td>
                    <td><span class="badge bg-success"><%= m.emplacement.code %></span></td>
                    <td><%= m.emplacement.zone.code %></td>
                    <td><%= m.magasinier.prenom %> <%= m.magasinier.nom %></td>
                    <td><%= m.dateCreation.toLocaleDateString('fr-FR') %></td>
                    <td><%= m.dateValidation ? m.dateValidation.toLocaleDateString('fr-FR') : '-' %></td>
                    <td><a href="/emplacements/affectation-pdf/<%= m.id %>" class="btn btn-sm btn-outline-danger">PDF</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>

        <% if (missions.length === 0) { %>
            <div class="alert alert-info">Aucune mission d'affectation pour le moment.</div>
        <% } %>
    </div>
</body>
</html>