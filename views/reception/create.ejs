<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Nouveau Bon de Réception</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Nouveau Bon de Réception</h2>
        <form action="/reception/create" method="POST">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Numéro</label>
                    <input type="text" name="numero" class="form-control" placeholder="BR-001" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Fournisseur</label>
                    <select name="fournisseurId" class="form-select" required>
                        <% fournisseurs.forEach(f => { %>
                        <option value="<%= f.id %>"><%= f.nom %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
            <h5>Lignes</h5>
            <div id="lignes">
                <div class="row g-2 mb-2 ligne">
                    <div class="col-md-4">
                        <select name="articleIds" class="form-select" required>
                            <% articles.forEach(a => { %>
                            <option value="<%= a.id %>"><%= a.reference %> - <%= a.designation %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input type="number" name="quantitesCommandees" class="form-control" placeholder="Qté commandée" required>
                    </div>
                    <div class="col-md-3">
                        <input type="number" name="quantitesRecues" class="form-control" placeholder="Qté reçue" required>
                    </div>
                </div>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="ajouterLigne()">+ Ajouter ligne</button>
            <div>
                <button type="submit" class="btn btn-warning">Créer</button>
                <a href="/reception" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
    <script>
    function ajouterLigne() {
        const ligne = document.querySelector('.ligne').cloneNode(true);
        ligne.querySelectorAll('input').forEach(i => i.value = '');
        document.getElementById('lignes').appendChild(ligne);
    }
    </script>
</body>
</html>