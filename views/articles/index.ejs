<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Articles</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Articles</h2>
            <div>
                <a href="/articles/stock" class="btn btn-outline-primary">Consulter stock</a>
                <a href="/articles/create" class="btn btn-primary">+ Nouvel article</a>
            </div>
        </div>
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Référence</th><th>Désignation</th><th>Catégorie</th>
                    <th>Dimensions (LxlxH)</th><th>Poids</th><th>Prix</th><th>CUMP</th>
                    <th>Emplacement</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% articles.forEach(a => { %>
                <tr>
                    <td><%= a.reference %></td>
                    <td><%= a.designation %></td>
                    <td><%= a.categorie ? a.categorie.nom : '-' %></td>
                    <td><%= a.longueur %>x<%= a.largeur %>x<%= a.hauteur %> cm</td>
                    <td><%= a.poids %> kg</td>
                    <td><%= a.prix.toFixed(2) %> DH</td>
                    <td><%= a.coutMoyenPondere.toFixed(2) %> DH</td>
                    <td><%= a.emplacement ? a.emplacement.code : 'Non affecté' %></td>
                    <td>
                        <a href="/articles/edit/<%= a.id %>" class="btn btn-sm btn-warning">Modifier</a>
                        <form action="/articles/delete/<%= a.id %>" method="POST" class="d-inline">
                            <button class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>