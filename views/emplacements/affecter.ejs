<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Affecter Article</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Affecter un Article à un Emplacement</h2>
        <p class="text-muted">L'affectation vérifie automatiquement les dimensions et le poids.</p>
        <form action="/emplacements/affecter" method="POST" class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Article (non affecté)</label>
                <select name="articleId" class="form-select" required>
                    <% articles.forEach(a => { %>
                    <option value="<%= a.id %>"><%= a.reference %> - <%= a.designation %> (<%= a.longueur %>x<%= a.largeur %>x<%= a.hauteur %> cm, <%= a.poids %> kg)</option>
                    <% }) %>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Emplacement (libre)</label>
                <select name="emplacementId" class="form-select" required>
                    <% emplacements.forEach(e => { %>
                    <option value="<%= e.id %>"><%= e.code %> - Zone <%= e.zone.code %> (<%= e.longueur %>x<%= e.largeur %>x<%= e.hauteur %> cm, max <%= e.poidsMax %> kg)</option>
                    <% }) %>
                </select>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Affecter</button>
                <a href="/emplacements" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</body>
</html>