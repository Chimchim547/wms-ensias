<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Transfert</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Déplacer un Article</h2>
        <p class="text-muted">Le système filtre automatiquement les emplacements compatibles selon les dimensions et le poids de l'article.</p>

        <form action="/mouvements/transfert" method="POST" class="col-md-8">
            <div class="mb-3">
                <label class="form-label">Article à déplacer</label>
                <select name="articleId" class="form-select" id="articleSelect" required>
                    <option value="">-- Sélectionnez un article --</option>
                    <% articles.forEach(a => { %>
                    <option value="<%= a.id %>"
                        data-longueur="<%= a.longueur %>"
                        data-largeur="<%= a.largeur %>"
                        data-hauteur="<%= a.hauteur %>"
                        data-poids="<%= a.poids %>"
                        data-actuel="<%= a.emplacement.code %> - Zone <%= a.emplacement.zone.code %>"
                        data-compatibles="<%= JSON.stringify(a.compatibles.map(c => c.id)) %>">
                        <%= a.reference %> - <%= a.designation %> (Actuel: <%= a.emplacement.code %> - Zone <%= a.emplacement.zone.code %>)
                    </option>
                    <% }) %>
                </select>
            </div>

            <!-- Détails article sélectionné -->
            <div id="articleDetails" class="card mb-3" style="display:none;">
                <div class="card-body">
                    <h6>Article sélectionné :</h6>
                    <div class="row">
                        <div class="col-md-3"><span class="badge bg-secondary p-2" id="artActuel"></span></div>
                        <div class="col-md-2"><span class="badge bg-primary p-2" id="artLongueur"></span></div>
                        <div class="col-md-2"><span class="badge bg-primary p-2" id="artLargeur"></span></div>
                        <div class="col-md-2"><span class="badge bg-primary p-2" id="artHauteur"></span></div>
                        <div class="col-md-2"><span class="badge bg-primary p-2" id="artPoids"></span></div>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Nouvel emplacement (compatible)</label>
                <select name="newEmplacementId" class="form-select" id="emplacementSelect" required>
                    <option value="">-- Sélectionnez d'abord un article --</option>
                </select>
                <div id="noCompatible" class="alert alert-warning mt-2" style="display:none;">
                    Aucun emplacement compatible disponible pour cet article.
                </div>
                <div id="compatibleCount" class="text-success mt-1" style="display:none;"></div>
            </div>

            <button type="submit" class="btn btn-secondary" id="btnDeplacer" disabled>Déplacer</button>
            <a href="/mouvements" class="btn btn-outline-secondary">Annuler</a>
        </form>

        <!-- Tableau des emplacements libres -->
        <div class="mt-4">
            <h5>Emplacements libres disponibles</h5>
            <table class="table table-sm table-striped">
                <thead class="table-dark">
                    <tr><th>Code</th><th>Zone</th><th>Longueur</th><th>Largeur</th><th>Hauteur</th><th>Poids max</th></tr>
                </thead>
                <tbody>
                    <% emplacements.forEach(e => { %>
                    <tr id="emp-row-<%= e.id %>">
                        <td><%= e.code %></td>
                        <td><%= e.zone.code %></td>
                        <td><%= e.longueur %> cm</td>
                        <td><%= e.largeur %> cm</td>
                        <td><%= e.hauteur %> cm</td>
                        <td><%= e.poidsMax %> kg</td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
    const emplacementsData = <%- JSON.stringify(emplacements.map(e => ({
        id: e.id,
        code: e.code,
        zone: e.zone.code,
        longueur: e.longueur,
        largeur: e.largeur,
        hauteur: e.hauteur,
        poidsMax: e.poidsMax
    }))) %>;

    document.getElementById('articleSelect').addEventListener('change', function() {
        const selected = this.options[this.selectedIndex];
        const emplacementSelect = document.getElementById('emplacementSelect');
        const articleDetails = document.getElementById('articleDetails');
        const noCompatible = document.getElementById('noCompatible');
        const compatibleCount = document.getElementById('compatibleCount');
        const btnDeplacer = document.getElementById('btnDeplacer');

        emplacementSelect.innerHTML = '';
        noCompatible.style.display = 'none';
        compatibleCount.style.display = 'none';
        btnDeplacer.disabled = true;

        // Reset highlighting
        emplacementsData.forEach(e => {
            const row = document.getElementById('emp-row-' + e.id);
            if (row) { row.style.background = ''; row.style.fontWeight = ''; }
        });

        if (!this.value) {
            articleDetails.style.display = 'none';
            emplacementSelect.innerHTML = '<option value="">-- Sélectionnez d\'abord un article --</option>';
            return;
        }

        // Afficher détails
        document.getElementById('artActuel').textContent = 'Actuel: ' + selected.dataset.actuel;
        document.getElementById('artLongueur').textContent = 'L: ' + selected.dataset.longueur + ' cm';
        document.getElementById('artLargeur').textContent = 'l: ' + selected.dataset.largeur + ' cm';
        document.getElementById('artHauteur').textContent = 'H: ' + selected.dataset.hauteur + ' cm';
        document.getElementById('artPoids').textContent = 'P: ' + selected.dataset.poids + ' kg';
        articleDetails.style.display = 'block';

        // Filtrer compatibles
        const compatibleIds = JSON.parse(selected.dataset.compatibles);

        if (compatibleIds.length === 0) {
            emplacementSelect.innerHTML = '<option value="">Aucun emplacement compatible</option>';
            noCompatible.style.display = 'block';
            return;
        }

        compatibleCount.textContent = compatibleIds.length + ' emplacement(s) compatible(s)';
        compatibleCount.style.display = 'block';

        emplacementSelect.innerHTML = '<option value="">-- Choisir un emplacement --</option>';

        emplacementsData.forEach(e => {
            if (compatibleIds.includes(e.id)) {
                const option = document.createElement('option');
                option.value = e.id;
                option.textContent = e.code + ' - Zone ' + e.zone + ' (' + e.longueur + 'x' + e.largeur + 'x' + e.hauteur + ' cm, max ' + e.poidsMax + ' kg)';
                emplacementSelect.appendChild(option);

                const row = document.getElementById('emp-row-' + e.id);
                if (row) { row.style.background = '#d4edda'; row.style.fontWeight = 'bold'; }
            }
        });

        btnDeplacer.disabled = false;
    });

    document.getElementById('emplacementSelect').addEventListener('change', function() {
        document.getElementById('btnDeplacer').disabled = !this.value;
    });
    </script>
</body>
</html>