<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Emplacements</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Emplacements</h2>
            <div>
                <a href="/emplacements/affecter" class="btn btn-outline-primary">Affecter article</a>
                <a href="/emplacements/create" class="btn btn-primary">+ Nouvel emplacement</a>
            </div>
        </div>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Code</th>
                    <th>Zone</th>
                    <th>Dimensions</th>
                    <th>Poids max</th>
                    <th>Statut</th>
                    <th>Article</th>
                    <th>Quantité</th>
                    <th>Capacité</th>
                    
                </tr>
            </thead>
            <tbody>
                <% emplacements.forEach(e => { %>
                    <% if (e.stockEmplacements && e.stockEmplacements.length > 0) { %>
                        <%
                        const totalQte = e.stockEmplacements.reduce((sum, s) => sum + s.quantite, 0);
                        const art = e.stockEmplacements[0].article;
                        const volEmp = e.longueur * e.largeur * e.hauteur;
                        const volArt = art.longueur * art.largeur * art.hauteur;
                        const capVol = volArt > 0 ? Math.floor(volEmp / volArt) : 1;
                        const capPoids = art.poids > 0 ? Math.floor(e.poidsMax / art.poids) : capVol;
                        const capMax = Math.min(capVol, capPoids);
                        %>
                        <% e.stockEmplacements.forEach((se, idx) => { %>
                        <tr class="table-warning">
                            <td><%= e.code %></td>
                            <td><%= e.zone.code %></td>
                            <td><%= e.longueur %>x<%= e.largeur %>x<%= e.hauteur %> cm</td>
                            <td><%= e.poidsMax %> kg</td>
                            <td>
                                <% if (totalQte >= capMax) { %>
                                    <span class="badge bg-danger">Plein</span>
                                <% } else { %>
                                    <span class="badge bg-warning text-dark">Partiel</span>
                                <% } %>
                            </td>
                            <td><%= se.article.reference %> - <%= se.article.designation %></td>
                            <td><strong><%= se.quantite %></strong></td>
                            <td><%= totalQte %>/<%= capMax %></td>
                            
                        </tr>
                        <% }) %>
                    <% } else { %>
                    <tr>
                        <td><%= e.code %></td>
                        <td><%= e.zone.code %></td>
                        <td><%= e.longueur %>x<%= e.largeur %>x<%= e.hauteur %> cm</td>
                        <td><%= e.poidsMax %> kg</td>
                        <td><span class="badge bg-success">Libre</span></td>
                        <td>-</td>
                        <td>-</td>
                        <td>-</td>
                       
                    </tr>
                    <% } %>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>