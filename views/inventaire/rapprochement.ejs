<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Rapprochement Automatique</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Rapprochement Automatique - Inventaire #<%= inventaire.id %></h2>
        
        <div class="alert alert-info">
            <h5>Résultat du rapprochement automatique</h5>
            <p>Le système a comparé les quantités comptées par le magasinier avec le stock théorique calculé à partir des mouvements de stock (entrées - sorties).</p>
        </div>

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card text-white <%= totalEcarts === 0 ? 'bg-success' : 'bg-danger' %> text-center p-3">
                    <h3><%= totalEcarts %></h3>
                    <p>Article(s) avec écart</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info text-center p-3">
                    <h3><%= resultats.length %></h3>
                    <p>Articles vérifiés</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white <%= valeurEcarts < 0 ? 'bg-danger' : 'bg-warning' %> text-center p-3">
                    <h3><%= valeurEcarts.toFixed(2) %> DH</h3>
                    <p>Valeur des écarts</p>
                </div>
            </div>
        </div>

        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Référence</th>
                    <th>Désignation</th>
                    <th>Stock Système</th>
                    <th>Qté Comptée</th>
                    <th>Écart</th>
                    <th>Valeur écart</th>
                    <th>Justificatif</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                <% resultats.forEach(r => { %>
                <tr class="<%= r.ecart !== 0 ? 'table-danger' : 'table-success' %>">
                    <td><strong><%= r.reference %></strong></td>
                    <td><%= r.designation %></td>
                    <td><%= r.stockSysteme %></td>
                    <td><%= r.quantiteReelle %></td>
                    <td>
                        <strong>
                        <% if (r.ecart > 0) { %>
                            <span class="text-primary">+<%= r.ecart %></span>
                        <% } else if (r.ecart < 0) { %>
                            <span class="text-danger"><%= r.ecart %></span>
                        <% } else { %>
                            <span class="text-success">0</span>
                        <% } %>
                        </strong>
                    </td>
                    <td><%= (r.ecart * r.cump).toFixed(2) %> DH</td>
                    <td>
  <%= r.justificatif || '-' %>
  <% if (r.ecartChange) { %>
    <br><span class="badge bg-warning text-dark">⚠ Écart modifié (comptage: <%= r.ancienEcart > 0 ? '+' : '' %><%= r.ancienEcart %> → rapprochement: <%= r.ecart > 0 ? '+' : '' %><%= r.ecart %>)</span>
  <% } %>
</td>
                    <td>
                        <% if (r.ecart === 0) { %>
                            <span class="badge bg-success">Conforme</span>
                        <% } else if (r.justificatif) { %>
                            <span class="badge bg-warning">Écart justifié</span>
                        <% } else { %>
                            <span class="badge bg-danger">Écart non justifié</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="d-flex gap-2 mt-3">
            <% if (totalEcarts === 0) { %>
                <div class="alert alert-success flex-grow-1">
                    <strong>Aucun écart détecté.</strong> Vous pouvez valider l'inventaire en toute confiance.
                </div>
            <% } else { %>
                <div class="alert alert-warning flex-grow-1">
                    <strong><%= totalEcarts %> écart(s) détecté(s)</strong> pour une valeur de <strong><%= valeurEcarts.toFixed(2) %> DH</strong>. 
                    Vérifiez les justificatifs avant de valider.
                </div>
            <% } %>
        </div>

        <div class="d-flex gap-2">
            <form action="/inventaire/valider/<%= inventaire.id %>" method="POST">
                <button class="btn btn-success btn-lg" onclick="return confirm('Valider définitivement cet inventaire ?')">Valider l'inventaire</button>
            </form>
            <a href="/inventaire" class="btn btn-secondary btn-lg">Retour</a>
        </div>
    </div>
</body>
</html>