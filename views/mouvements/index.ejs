<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Mouvements de Stock</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Mouvements de Stock</h2>
            <a href="/mouvements/transfert" class="btn btn-secondary">Déplacer un article</a>
        </div>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr><th>Date</th><th>Type</th><th>Article</th><th>Quantité</th></tr>
            </thead>
            <tbody>
                <% mouvements.forEach(m => { %>
                <tr>
                    <td><%= m.date.toLocaleDateString('fr-FR') %></td>
                    <td>
                        <span class="badge bg-<%= m.type === 'ENTREE' ? 'success' : m.type === 'SORTIE' ? 'danger' : 'info' %>">
                            <%= m.type %>
                        </span>
                    </td>
                    <td><%= m.article.reference %> - <%= m.article.designation %></td>
                    <td><%= m.quantite %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>