<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Fournisseurs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Fournisseurs</h2>
        <form action="/reception/fournisseurs/create" method="POST" class="row g-2 mb-4">
            <div class="col-md-3"><input type="text" name="nom" class="form-control" placeholder="Nom" required></div>
            <div class="col-md-3"><input type="text" name="adresse" class="form-control" placeholder="Adresse" required></div>
            <div class="col-md-2"><input type="text" name="telephone" class="form-control" placeholder="Téléphone" required></div>
            <div class="col-md-2"><input type="email" name="email" class="form-control" placeholder="Email" required></div>
            <div class="col-md-2"><button type="submit" class="btn btn-warning w-100">Ajouter</button></div>
        </form>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr><th>Nom</th><th>Adresse</th><th>Téléphone</th><th>Email</th></tr>
            </thead>
            <tbody>
                <% fournisseurs.forEach(f => { %>
                <tr><td><%= f.nom %></td><td><%= f.adresse %></td><td><%= f.telephone %></td><td><%= f.email %></td></tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>