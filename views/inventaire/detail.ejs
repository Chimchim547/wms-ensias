<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Détail Inventaire</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Détail Inventaire #<%= inventaire.id %></h2>
        <p>Planifié: <strong><%= inventaire.datePlanification.toLocaleDateString('fr-FR') %></strong>
        | Réalisé: <strong><%= inventaire.dateRealisation ? inventaire.dateRealisation.toLocaleDateString('fr-FR') : 'Non validé' %></strong>
        | Valeur d'inventaire: <strong><%= valeurInventaire.toFixed(2) %> DH</strong></p>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr><th>Référence</th><th>Désignation</th><th>Qté théorique</th><th>Qté réelle</th><th>Écart</th><th>Justificatif</th></tr>
            </thead>
            <tbody>
                <% inventaire.lignes.forEach(l => { %>
                <tr class="<%= l.ecart !== 0 ? 'table-warning' : '' %>">
                    <td><%= l.reference %></td>
                    <td><%= l.designation %></td>
                    <td><%= l.quantiteTheorique %></td>
                    <td><%= l.quantiteReelle %></td>
                    <td><strong class="<%= l.ecart > 0 ? 'text-success' : l.ecart < 0 ? 'text-danger' : '' %>"><%= l.ecart %></strong></td>
                    <td><%= l.justificatif || '-' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <a href="/inventaire" class="btn btn-secondary">Retour</a>
    </div>
</body>
</html>