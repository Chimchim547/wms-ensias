<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WMS ENSIAS - Connexion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0f1923 0%, #1a2332 50%, #0d1520 100%);
            position: relative;
            overflow: hidden;
        }

        /* Grid background */
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: 0;
        }

        /* Radial glow */
        body::after {
            content: '';
            position: absolute;
            top: -30%;
            left: -20%;
            width: 140%;
            height: 140%;
            background:
                radial-gradient(circle at 40% 30%, rgba(59,130,246,0.07) 0%, transparent 50%),
                radial-gradient(circle at 65% 70%, rgba(16,185,129,0.05) 0%, transparent 50%);
            animation: bgShift 15s ease-in-out infinite alternate;
            z-index: 0;
        }

        @keyframes bgShift {
            0% { transform: translate(0, 0); }
            100% { transform: translate(-2%, -2%); }
        }

        /* Floating icons */
        .float-icon {
            position: absolute;
            color: rgba(59,130,246,0.06);
            font-size: 2.5rem;
            animation: floatUp 20s linear infinite;
            z-index: 0;
        }
        .float-icon:nth-child(1) { left: 8%; animation-delay: 0s; animation-duration: 18s; font-size: 2.2rem; }
        .float-icon:nth-child(2) { left: 20%; animation-delay: -4s; animation-duration: 22s; font-size: 3rem; }
        .float-icon:nth-child(3) { left: 40%; animation-delay: -8s; animation-duration: 20s; }
        .float-icon:nth-child(4) { left: 60%; animation-delay: -12s; animation-duration: 24s; font-size: 2rem; }
        .float-icon:nth-child(5) { left: 78%; animation-delay: -6s; animation-duration: 19s; font-size: 2.8rem; }
        .float-icon:nth-child(6) { left: 90%; animation-delay: -15s; animation-duration: 21s; font-size: 2rem; }

        @keyframes floatUp {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; }
        }

        /* Main content */
        .main-content {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 480px;
            text-align: center;
            padding: 40px 30px;
        }

        /* Logo */
        .brand-logo {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, #3b82f6, #10b981);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 2rem;
            color: white;
            box-shadow: 0 16px 50px rgba(59,130,246,0.25);
            animation: logoIn 0.8s cubic-bezier(0.16,1,0.3,1) forwards;
            opacity: 0;
            transform: scale(0.5) rotate(-10deg);
        }

        @keyframes logoIn {
            to { opacity: 1; transform: scale(1) rotate(0deg); }
        }

        .brand-title {
            font-size: 2.4rem;
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
            margin-bottom: 4px;
            animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.15s forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .brand-title span {
            background: linear-gradient(135deg, #3b82f6, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-subtitle {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.35);
            font-weight: 300;
            letter-spacing: 4px;
            text-transform: uppercase;
            margin-bottom: 32px;
            animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.25s forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        @keyframes slideUp {
            to { opacity: 1; transform: translateY(0); }
        }

        /* Feature icons row */
        .features-row {
            display: flex;
            justify-content: center;
            gap: 24px;
            margin-bottom: 36px;
            animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.35s forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .feature-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .feature-icon {
            width: 44px;
            height: 44px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            transition: transform 0.3s;
        }

        .feature-item:hover .feature-icon {
            transform: translateY(-3px);
        }

        .feature-icon.blue { background: rgba(59,130,246,0.12); color: #3b82f6; }
        .feature-icon.green { background: rgba(16,185,129,0.12); color: #10b981; }
        .feature-icon.amber { background: rgba(245,158,11,0.12); color: #f59e0b; }
        .feature-icon.rose { background: rgba(244,63,94,0.12); color: #f43f5e; }

        .feature-label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.4);
            font-weight: 500;
        }

        /* Login card */
        .login-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 16px;
            padding: 32px;
            backdrop-filter: blur(10px);
            animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.45s forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-group label {
            display: block;
            color: rgba(255,255,255,0.45);
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 8px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.2);
            font-size: 1rem;
            transition: color 0.3s;
        }

        .input-wrapper input {
            width: 100%;
            padding: 14px 14px 14px 44px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            color: white;
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            transition: all 0.3s;
            outline: none;
        }

        .input-wrapper input::placeholder {
            color: rgba(255,255,255,0.18);
        }

        .input-wrapper input:focus {
            background: rgba(59,130,246,0.06);
            border-color: rgba(59,130,246,0.4);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.08);
        }

        .input-wrapper input:focus ~ i {
            color: #3b82f6;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            border-radius: 10px;
            color: white;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 4px;
            position: relative;
            overflow: hidden;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #10b981, #059669);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(59,130,246,0.3);
        }

        .btn-login:hover::before { opacity: 1; }

        .btn-login span {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-login:active { transform: translateY(0); }

        /* Footer */
        .login-footer {
            margin-top: 28px;
            animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.55s forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .status-dot {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: rgba(16,185,129,0.6);
            font-size: 0.75rem;
            font-weight: 400;
        }

        .status-dot::before {
            content: '';
            width: 7px;
            height: 7px;
            background: #10b981;
            border-radius: 50%;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16,185,129,0.4); }
            50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(16,185,129,0); }
        }

        .login-footer p {
            color: rgba(255,255,255,0.18);
            font-size: 0.72rem;
            font-weight: 300;
            margin-top: 12px;
        }

        .login-footer .school {
            color: rgba(59,130,246,0.5);
            font-weight: 500;
        }

        /* Responsive */
        @media (max-width: 520px) {
            .main-content { padding: 30px 20px; }
            .brand-title { font-size: 1.8rem; }
            .features-row { gap: 16px; }
            .login-card { padding: 24px; }
        }
    </style>
</head>
<body>
    <!-- Floating icons -->
    <i class="bi bi-box-seam float-icon"></i>
    <i class="bi bi-truck float-icon"></i>
    <i class="bi bi-clipboard-check float-icon"></i>
    <i class="bi bi-geo-alt float-icon"></i>
    <i class="bi bi-arrow-left-right float-icon"></i>
    <i class="bi bi-graph-up float-icon"></i>

    <div class="main-content">
        <!-- Logo -->
        <div class="brand-logo">
            <i class="bi bi-boxes"></i>
        </div>

        <!-- Title -->
        <h1 class="brand-title">WMS <span>ENSIAS</span></h1>
        <p class="brand-subtitle">Warehouse Management System</p>

        <!-- Feature icons -->
        <div class="features-row">
            <div class="feature-item">
                <div class="feature-icon blue"><i class="bi bi-box-seam"></i></div>
                <span class="feature-label">Stock</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon green"><i class="bi bi-geo-alt"></i></div>
                <span class="feature-label">Entrepôt</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon amber"><i class="bi bi-truck"></i></div>
                <span class="feature-label">Expédition</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon rose"><i class="bi bi-clipboard-check"></i></div>
                <span class="feature-label">Qualité</span>
            </div>
        </div>

        <!-- Login form -->
        <div class="login-card">
            <form action="/login" method="POST">
                <div class="form-group">
                    <label>Adresse email</label>
                    <div class="input-wrapper">
                        <input type="email" name="email" placeholder="votre@email.com" required>
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>
                <div class="form-group">
                    <label>Mot de passe</label>
                    <div class="input-wrapper">
                        <input type="password" name="password" placeholder="••••••••" required>
                        <i class="bi bi-lock"></i>
                    </div>
                </div>
                <button type="submit" class="btn-login">
                    <span>Se connecter <i class="bi bi-arrow-right"></i></span>
                </button>
            </form>
        </div>

        <!-- Footer -->
        <div class="login-footer">
            <div class="status-dot">Système opérationnel</div>
            <p>Projet WMS — <span class="school">ENSIAS</span> 2026</p>
        </div>
    </div>
</body>
</html>
