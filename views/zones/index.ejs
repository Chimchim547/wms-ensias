<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Zones</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Zones</h2>
            <div>
                <a href="/zones/plan" class="btn btn-outline-success">Plan visuel</a>
                <a href="/zones/create" class="btn btn-success">+ Nouvelle zone</a>
            </div>
        </div>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr><th>Code</th><th>Type</th><th>Catégorie</th><th>Dimensions max</th><th>Poids max</th><th>Couleur</th><th>Emplacements</th><th>Actions</th></tr>
            </thead>
            <tbody>
                <% zones.forEach(z => { %>
                <tr>
                    <td><%= z.code %></td>
                    <td><%= z.type %></td>
                    <td><%= z.categorie ? z.categorie.nom : '-' %></td>
                    <td><%= z.dimensionMaxLongueur %>x<%= z.dimensionMaxLargeur %>x<%= z.dimensionMaxHauteur %> cm</td>
                    <td><%= z.poidsMax %> kg</td>
                    <td><span style="display:inline-block;width:20px;height:20px;background:<%= z.couleur %>;border:1px solid #ccc;"></span> <%= z.couleur %></td>
                    <td><%= z.emplacements.length %></td>
                    <td>
                        <a href="/zones/edit/<%= z.id %>" class="btn btn-sm btn-warning">Modifier</a>
                        <form action="/zones/delete/<%= z.id %>" method="POST" class="d-inline">
                            <button class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>