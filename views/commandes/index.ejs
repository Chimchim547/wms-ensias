<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Commandes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Commandes</h2>
            <a href="/commandes/create" class="btn btn-info">+ Nouvelle commande</a>
        </div>

        <!-- Filtres -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Filtrer par statut</label>
                        <select class="form-select" onchange="window.location.href='/commandes?statut='+this.value">
                            <option value="" <%= !filtres.statut ? 'selected' : '' %>>Tous les statuts</option>
                            <option value="EN_ATTENTE" <%= filtres.statut === 'EN_ATTENTE' ? 'selected' : '' %>>En attente</option>
                            <option value="PICKING" <%= filtres.statut === 'PICKING' ? 'selected' : '' %>>Picking généré</option>
                            <option value="PARTIELLE" <%= filtres.statut === 'PARTIELLE' ? 'selected' : '' %>>Partielle</option>
                            <option value="PREPARE" <%= filtres.statut === 'PREPARE' ? 'selected' : '' %>>Préparée</option>
                            <option value="AU_QUAI" <%= filtres.statut === 'AU_QUAI' ? 'selected' : '' %>>Au quai</option>
                            <option value="EXPEDIEE" <%= filtres.statut === 'EXPEDIEE' ? 'selected' : '' %>>Expédiée</option>
                            <option value="EN_ATTENTE_STOCK" <%= filtres.statut === 'EN_ATTENTE_STOCK' ? 'selected' : '' %>>En attente stock</option>
                            <option value="BACKORDER" <%= filtres.statut === 'BACKORDER' ? 'selected' : '' %>>Backorder</option>
                            <option value="ANNULEE" <%= filtres.statut === 'ANNULEE' ? 'selected' : '' %>>Annulée</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Rechercher</label>
                        <form action="/commandes" method="GET" class="d-flex">
                            <input type="hidden" name="statut" value="<%= filtres.statut || '' %>">
                            <input type="text" name="recherche" class="form-control" placeholder="Numéro ou nom client..." value="<%= filtres.recherche || '' %>">
                            <button type="submit" class="btn btn-primary ms-2">🔍</button>
                        </form>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <% if (filtres.statut || filtres.recherche) { %>
                            <a href="/commandes" class="btn btn-outline-secondary">Réinitialiser</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <p class="text-muted"><%= commandes.length %> commande(s) trouvée(s)</p>

        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Numéro</th>
                    <th>Date création</th>
                    <th>Client</th>
                    <th>Total</th>
                    <th>Articles</th>
                    <th>Statut</th>
                    <th>Date expédition</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% commandes.forEach(c => { %>
                <tr class="<%= c.statut === 'BACKORDER' ? 'table-warning' : '' %>">
                    <td>
                        <%= c.numero %>
                        <% if (c.commandeParentId) { %>
                            <br><small class="text-muted">↳ de CMD originale</small>
                        <% } %>
                    </td>
                    <td><%= c.date.toLocaleDateString('fr-FR') %></td>
                    <td><%= c.nomClient %></td>
                    <td><%= c.prixTotal.toFixed(2) %> DH</td>
                    <td><%= c.lignes.length %> (<%= c.lignes.reduce((sum, l) => sum + l.quantite, 0) %> unités)</td>
                    <td>
                        <% if (c.statut === 'EN_ATTENTE') { %>
                            <span class="badge bg-secondary">En attente</span>
                        <% } else if (c.statut === 'PICKING') { %>
                            <span class="badge bg-primary">Picking généré</span>
                        <% } else if (c.statut === 'PARTIELLE') { %>
                            <span class="badge bg-warning">⚠ Partielle</span>
                        <% } else if (c.statut === 'EN_ATTENTE_STOCK') { %>
                            <span class="badge bg-info">En attente stock</span>
                        <% } else if (c.statut === 'PREPARE') { %>
                            <span class="badge bg-success">Préparée</span>
                        <% } else if (c.statut === 'AU_QUAI') { %>
                            <span class="badge bg-info">Au quai</span>
                        <% } else if (c.statut === 'EXPEDIEE') { %>
                            <span class="badge bg-success">Expédiée ✓</span>
                        <% } else if (c.statut === 'BACKORDER') { %>
                            <span class="badge bg-warning text-dark">📦 Backorder</span>
                        <% } else if (c.statut === 'ANNULEE') { %>
                            <span class="badge bg-danger">Annulée</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (c.statut === 'EXPEDIEE' && c.dateExpedition) { %>
                            <%= c.dateExpedition.toLocaleDateString('fr-FR') %>
                        <% } else { %>
                            <span class="text-muted">-</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (c.statut === 'EN_ATTENTE') { %>
                            <form action="/commandes/picking/<%= c.id %>" method="POST" class="d-inline">
                                <select name="modePicking" class="form-select form-select-sm d-inline-block" style="width: 120px;" onchange="toggleMagasinier(this)">
                                    <option value="SERIE">Série</option>
                                    <option value="PARALLELE">Parallèle</option>
                                </select>
                                <select name="magasinierSerie" class="form-select form-select-sm magasinier-select" style="width: 150px; display: none;">
                                    <option value="">-- Magasinier --</option>
                                    <% if (typeof magasiniers !== 'undefined') { %>
                                        <% magasiniers.forEach(m => { %>
                                        <option value="<%= m.id %>"><%= m.prenom %> <%= m.nom %></option>
                                        <% }) %>
                                    <% } %>
                                </select>
                                <button class="btn btn-sm btn-primary">Générer picking</button>
                            </form>
                        <% } else if (c.statut === 'BACKORDER') { %>
                            <% if (c.stockDispo) { %>
                                <span class="text-success">Stock disponible ✓</span>
                                <form action="/commandes/relancer-backorder/<%= c.id %>" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-success ms-1" onclick="return confirm('Relancer ce backorder en picking ?')">Relancer</button>
                                </form>
                            <% } else { %>
                                <span class="text-danger">⏳ En attente réappro</span>
                            <% } %>
                        <% } else if (c.statut === 'EN_ATTENTE_STOCK') { %>
                            <% if (c.stockDispo) { %>
                                <form action="/commandes/relancer-attente/<%= c.id %>" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-success" onclick="return confirm('Relancer le picking ?')">Relancer picking</button>
                                </form>
                            <% } else { %>
                                <span class="badge bg-warning">En attente stock</span>
                            <% } %>
                        <% } else if (c.statut === 'EXPEDIEE') { %>
                            <span class="text-success">Terminée</span>
                            <a href="/commandes/pdf/<%= c.id %>" class="btn btn-sm btn-outline-danger ms-1">BL</a>
                            <a href="/commandes/facture/<%= c.id %>" class="btn btn-sm btn-outline-dark ms-1">Facture</a>
                        <% } else if (c.statut === 'ANNULEE') { %>
                            <span class="text-danger">Annulée</span>
                        <% } else { %>
                            <a href="/commandes/picking/<%= c.id %>" class="btn btn-sm btn-outline-primary">
                                <%= c.statut === 'PARTIELLE' ? '⚠ Décision' : 'Voir picking' %>
                            </a>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="card mt-4">
            <div class="card-body">
                <h5>Flux de préparation d'une commande</h5>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge bg-secondary p-2">1. Créer commande</span>
                    <span>→</span>
                    <span class="badge bg-primary p-2">2. Générer picking</span>
                    <span>→</span>
                    <span class="badge bg-warning p-2">3. Magasinier prélève</span>
                    <span>→</span>
                    <span class="badge bg-danger p-2">Si partiel → Décision client</span>
                    <span>→</span>
                    <span class="badge bg-dark p-2">📦 Backorder (si manquant)</span>
                    <span>→</span>
                    <span class="badge bg-info p-2">4. Déplacer vers quai</span>
                    <span>→</span>
                    <span class="badge bg-success p-2">5. Expédier</span>
                </div>
            </div>
        </div>
    </div>
    <script>
function toggleMagasinier(select) {
    const form = select.closest('form');
    const magSelect = form.querySelector('.magasinier-select');
    if (select.value === 'SERIE') {
        magSelect.style.display = 'inline-block';
        magSelect.required = true;
        magSelect.name = 'magasinierSerie';
    } else {
        magSelect.style.display = 'none';
        magSelect.required = false;
        magSelect.name = '';
    }
}
</script>
</body>
</html>