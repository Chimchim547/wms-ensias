<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Inventaires</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Inventaires</h2>
            <% if (user.role === 'MAGASINIER' || user.role === 'ADMINISTRATEUR') { %>
                <a href="/inventaire/planifier" class="btn btn-danger">+ Planifier inventaire</a>
            <% } %>
        </div>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr><th>ID</th><th>Date planification</th><th>Date réalisation</th><th>Articles</th><th>Statut</th><th>Actions</th></tr>
            </thead>
            <tbody>
                <% inventaires.forEach(inv => { %>
                <tr>
                    <td>#<%= inv.id %></td>
                    <td><%= inv.datePlanification.toLocaleDateString('fr-FR') %></td>
                    <td><%= inv.dateRealisation ? inv.dateRealisation.toLocaleDateString('fr-FR') : '-' %></td>
                    <td><%= inv.lignes.length %></td>
                    <td>
                        <% if (inv.dateRealisation) { %>
                            <span class="badge bg-success">Validé</span>
                        <% } else { %>
                            <% const comptageEffectue = inv.lignes.some(l => l.quantiteReelle > 0); %>
                            <% if (comptageEffectue) { %>
                                <span class="badge bg-info">Compté</span>
                            <% } else { %>
                                <span class="badge bg-warning">En cours</span>
                            <% } %>
                        <% } %>
                    </td>
                    <td>
                        <% if (!inv.dateRealisation) { %>
                            <% if (user.role === 'MAGASINIER' || user.role === 'ADMINISTRATEUR') { %>
                                <a href="/inventaire/comptage/<%= inv.id %>" class="btn btn-sm btn-primary">Comptage</a>
                            <% } %>
                            <% if (user.role === 'RESPONSABLE_ENTREPOT' || user.role === 'ADMINISTRATEUR') { %>
                                <form action="/inventaire/rapprochement/<%= inv.id %>" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-warning">Rapprochement</button>
                                </form>
                                <form action="/inventaire/valider/<%= inv.id %>" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-success" onclick="return confirm('Valider cet inventaire ?')">Valider</button>
                                </form>
                            <% } %>
                        <% } %>
                        <a href="/inventaire/detail/<%= inv.id %>" class="btn btn-sm btn-outline-info">Détail</a>
                        <a href="/inventaire/pdf/<%= inv.id %>" class="btn btn-sm btn-outline-danger">PDF</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>