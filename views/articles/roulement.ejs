<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Taux de Rotation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Taux de Rotation du Stock</h2>
        <p class="text-muted">Le taux de rotation mesure combien de fois le stock est renouvelé sur une période. La couverture indique combien de jours le stock peut tenir sans réapprovisionnement.</p>
        
        <div class="alert alert-info">
            <strong>Formules :</strong><br>
            Taux de rotation = Consommation (sorties) / Stock moyen<br>
            Couverture de stock (jours) = 365 / Taux de rotation
        </div>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body text-center">
                        <h3><%= tauxGlobal %></h3>
                        <p>Taux de rotation global</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body text-center">
                        <h3><%= couvertureGlobale %> jours</h3>
                        <p>Couverture globale</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-danger">
                    <div class="card-body text-center">
                        <h3><%= totalCoutSorties %> DH</h3>
                        <p>Coût total des sorties</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body text-center">
                        <h3><%= articles.length %></h3>
                        <p>Articles analysés</p>
                    </div>
                </div>
            </div>
        </div>

        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Référence</th>
                    <th>Désignation</th>
                    <th>Catégorie</th>
                    <th>Entrées</th>
                    <th>Sorties</th>
                    <th>Stock actuel</th>
                    <th>Stock moyen</th>
                    <th>CUMP</th>
                    <th>Taux rotation</th>
                    <th>Couverture</th>
                    <th>Performance</th>
                </tr>
            </thead>
            <tbody>
                <% articles.forEach(a => { %>
                <tr>
                    <td><%= a.reference %></td>
                    <td><%= a.designation %></td>
                    <td><%= a.categorie ? a.categorie.nom : '-' %></td>
                    <td class="text-success"><strong><%= a.entrees %></strong></td>
                    <td class="text-danger"><strong><%= a.sorties %></strong></td>
                    <td><%= a.stock %></td>
                    <td><%= a.stockMoyen %></td>
                    <td><%= a.coutMoyenPondere.toFixed(2) %> DH</td>
                    <td><strong><%= a.tauxRotation %></strong></td>
                    <td>
                        <% if (a.couverture === 'N/A') { %>
                            <span class="text-muted">N/A</span>
                        <% } else { %>
                            <strong><%= a.couverture %> jours</strong>
                        <% } %>
                    </td>
                    <td>
                        <% if (parseFloat(a.tauxRotation) >= 4) { %>
                            <span class="badge bg-success">Excellent</span>
                        <% } else if (parseFloat(a.tauxRotation) >= 2) { %>
                            <span class="badge bg-info">Bon</span>
                        <% } else if (parseFloat(a.tauxRotation) >= 1) { %>
                            <span class="badge bg-warning">Moyen</span>
                        <% } else { %>
                            <span class="badge bg-danger">Faible</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        
        
        <a href="/dashboard" class="btn btn-secondary mt-3">Retour au dashboard</a>
    </div>
</body>
</html>