<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WMS ENSIAS - Connexion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            display: flex;
            background: #0a0e17;
            overflow: hidden;
        }

        /* Left panel - Branding */
        .brand-panel {
            width: 55%;
            background: linear-gradient(135deg, #0f1923 0%, #1a2332 50%, #0d1520 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
            padding: 60px;
        }

        .brand-panel::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(circle at 30% 40%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 60%, rgba(16, 185, 129, 0.06) 0%, transparent 50%);
            animation: bgShift 15s ease-in-out infinite alternate;
        }

        @keyframes bgShift {
            0% { transform: translate(0, 0) rotate(0deg); }
            100% { transform: translate(-3%, -3%) rotate(2deg); }
        }

        /* Grid pattern overlay */
        .grid-overlay {
            position: absolute;
            inset: 0;
            background-image: 
                linear-gradient(rgba(59, 130, 246, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59, 130, 246, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        /* Floating warehouse icons */
        .float-icon {
            position: absolute;
            color: rgba(59, 130, 246, 0.07);
            font-size: 3rem;
            animation: floatUp 20s linear infinite;
        }
        .float-icon:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 18s; font-size: 2.5rem; }
        .float-icon:nth-child(2) { left: 25%; animation-delay: -4s; animation-duration: 22s; font-size: 3.5rem; }
        .float-icon:nth-child(3) { left: 45%; animation-delay: -8s; animation-duration: 20s; }
        .float-icon:nth-child(4) { left: 65%; animation-delay: -12s; animation-duration: 24s; font-size: 2rem; }
        .float-icon:nth-child(5) { left: 80%; animation-delay: -6s; animation-duration: 19s; font-size: 2.8rem; }
        .float-icon:nth-child(6) { left: 35%; animation-delay: -15s; animation-duration: 21s; font-size: 2.2rem; }

        @keyframes floatUp {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; }
        }

        .brand-content {
            position: relative;
            z-index: 2;
            text-align: center;
            max-width: 500px;
        }

        .brand-logo {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #3b82f6, #10b981);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            font-size: 2.2rem;
            color: white;
            box-shadow: 0 20px 60px rgba(59, 130, 246, 0.3);
            animation: logoEntry 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: scale(0.5) rotate(-10deg);
        }

        @keyframes logoEntry {
            to { opacity: 1; transform: scale(1) rotate(0deg); }
        }

        .brand-title {
            font-size: 2.8rem;
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
            margin-bottom: 8px;
            animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        .brand-title span {
            background: linear-gradient(135deg, #3b82f6, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-subtitle {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.4);
            font-weight: 300;
            letter-spacing: 4px;
            text-transform: uppercase;
            margin-bottom: 50px;
            animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        @keyframes slideUp {
            to { opacity: 1; transform: translateY(0); }
        }

        /* Feature cards */
        .features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            width: 100%;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 14px;
            padding: 20px;
            display: flex;
            align-items: flex-start;
            gap: 14px;
            backdrop-filter: blur(10px);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            animation: cardEntry 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: translateY(20px);
        }
        .feature-card:nth-child(1) { animation-delay: 0.5s; }
        .feature-card:nth-child(2) { animation-delay: 0.6s; }
        .feature-card:nth-child(3) { animation-delay: 0.7s; }
        .feature-card:nth-child(4) { animation-delay: 0.8s; }

        @keyframes cardEntry {
            to { opacity: 1; transform: translateY(0); }
        }

        .feature-card:hover {
            background: rgba(59, 130, 246, 0.06);
            border-color: rgba(59, 130, 246, 0.15);
            transform: translateY(-2px);
        }

        .feature-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .feature-icon.blue { background: rgba(59, 130, 246, 0.12); color: #3b82f6; }
        .feature-icon.green { background: rgba(16, 185, 129, 0.12); color: #10b981; }
        .feature-icon.amber { background: rgba(245, 158, 11, 0.12); color: #f59e0b; }
        .feature-icon.rose { background: rgba(244, 63, 94, 0.12); color: #f43f5e; }

        .feature-text h4 {
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .feature-text p {
            color: rgba(255, 255, 255, 0.35);
            font-size: 0.75rem;
            font-weight: 300;
            line-height: 1.4;
        }

        /* Right panel - Login form */
        .login-panel {
            width: 45%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px;
            background: #0f1319;
            position: relative;
        }

        .login-panel::before {
            content: '';
            position: absolute;
            left: 0;
            top: 10%;
            bottom: 10%;
            width: 1px;
            background: linear-gradient(to bottom, transparent, rgba(59, 130, 246, 0.2), transparent);
        }

        .login-container {
            width: 100%;
            max-width: 380px;
            animation: formEntry 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
            opacity: 0;
            transform: translateX(30px);
        }

        @keyframes formEntry {
            to { opacity: 1; transform: translateX(0); }
        }

        .login-header {
            margin-bottom: 40px;
        }

        .login-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: white;
            margin-bottom: 8px;
        }

        .login-header p {
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.9rem;
            font-weight: 300;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-group label {
            display: block;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 10px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.25);
            font-size: 1.1rem;
            transition: color 0.3s;
        }

        .input-wrapper input {
            width: 100%;
            padding: 16px 16px 16px 48px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            color: white;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            font-weight: 400;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            outline: none;
        }

        .input-wrapper input::placeholder {
            color: rgba(255, 255, 255, 0.2);
        }

        .input-wrapper input:focus {
            background: rgba(59, 130, 246, 0.06);
            border-color: rgba(59, 130, 246, 0.4);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.08);
        }

        .input-wrapper input:focus + i,
        .input-wrapper input:focus ~ i {
            color: #3b82f6;
        }

        .btn-login {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            border-radius: 12px;
            color: white;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
            margin-top: 8px;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #10b981, #059669);
            opacity: 0;
            transition: opacity 0.4s;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(59, 130, 246, 0.3);
        }

        .btn-login:hover::before {
            opacity: 1;
        }

        .btn-login span {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-login:active {
            transform: translateY(0);
        }

        /* Footer */
        .login-footer {
            margin-top: 40px;
            text-align: center;
        }

        .login-footer p {
            color: rgba(255, 255, 255, 0.2);
            font-size: 0.75rem;
            font-weight: 300;
        }

        .login-footer .school {
            color: rgba(59, 130, 246, 0.5);
            font-weight: 500;
        }

        /* Pulse dot */
        .status-dot {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: rgba(16, 185, 129, 0.6);
            font-size: 0.75rem;
            font-weight: 400;
            margin-top: 16px;
        }

        .status-dot::before {
            content: '';
            width: 8px;
            height: 8px;
            background: #10b981;
            border-radius: 50%;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            50% { opacity: 0.7; box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
        }

        /* Responsive */
        @media (max-width: 968px) {
            body { flex-direction: column; }
            .brand-panel { width: 100%; min-height: 40vh; padding: 40px 30px; }
            .login-panel { width: 100%; min-height: 60vh; padding: 40px 30px; }
            .login-panel::before { display: none; }
            .brand-title { font-size: 2rem; }
            .features { grid-template-columns: 1fr; }
        }

        @media (max-width: 480px) {
            .brand-panel { padding: 30px 20px; min-height: 30vh; }
            .login-panel { padding: 30px 20px; }
            .features { display: none; }
        }
    </style>
</head>
<body>
    <!-- Left Panel - Branding -->
    <div class="brand-panel">
        <div class="grid-overlay"></div>
        
        <!-- Floating icons -->
        <i class="bi bi-box-seam float-icon"></i>
        <i class="bi bi-truck float-icon"></i>
        <i class="bi bi-clipboard-check float-icon"></i>
        <i class="bi bi-geo-alt float-icon"></i>
        <i class="bi bi-arrow-left-right float-icon"></i>
        <i class="bi bi-graph-up float-icon"></i>

        <div class="brand-content">
            <div class="brand-logo">
                <i class="bi bi-boxes"></i>
            </div>
            <h1 class="brand-title">WMS <span>ENSIAS</span></h1>
            <p class="brand-subtitle">Warehouse Management System</p>

            <div class="features">
                <div class="feature-card">
                    <div class="feature-icon blue"><i class="bi bi-box-seam"></i></div>
                    <div class="feature-text">
                        <h4>Gestion de Stock</h4>
                        <p>Suivi en temps réel avec CUMP et alertes</p>
                    </div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon green"><i class="bi bi-geo-alt"></i></div>
                    <div class="feature-text">
                        <h4>Plan Entrepôt</h4>
                        <p>Visualisation interactive des zones</p>
                    </div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon amber"><i class="bi bi-truck"></i></div>
                    <div class="feature-text">
                        <h4>Expédition</h4>
                        <p>Picking série/parallèle et LIFO/FIFO</p>
                    </div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon rose"><i class="bi bi-clipboard-check"></i></div>
                    <div class="feature-text">
                        <h4>Contrôle Qualité</h4>
                        <p>Réception, quarantaine et traçabilité</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel - Login -->
    <div class="login-panel">
        <div class="login-container">
            <div class="login-header">
                <h2>Bienvenue</h2>
                <p>Connectez-vous pour accéder à votre espace</p>
            </div>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label>Adresse email</label>
                    <div class="input-wrapper">
                        <input type="email" name="email" placeholder="votre@email.com" required>
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label>Mot de passe</label>
                    <div class="input-wrapper">
                        <input type="password" name="password" placeholder="••••••••" required>
                        <i class="bi bi-lock"></i>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <span>
                        Se connecter
                        <i class="bi bi-arrow-right"></i>
                    </span>
                </button>
            </form>

            <div class="login-footer">
                <div class="status-dot">Système opérationnel</div>
                <p style="margin-top: 20px;">
                    Projet WMS — <span class="school">ENSIAS</span> 2026S
                </p>
            </div>
        </div>
    </div>
</body>
</html>
