<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Modifier Article</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Modifier Article</h2>
        <form action="/articles/edit/<%= article.id %>" method="POST" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Référence</label>
                <input type="text" name="reference" class="form-control" value="<%= article.reference %>" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Désignation</label>
                <input type="text" name="designation" class="form-control" value="<%= article.designation %>" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Catégorie</label>
                <select name="categorieId" class="form-select" required>
                    <% categories.forEach(c => { %>
                    <option value="<%= c.id %>" <%= c.id === article.categorieId ? 'selected' : '' %>><%= c.nom %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Unité</label>
                <input type="text" name="unite" class="form-control" value="<%= article.unite %>" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Longueur (cm)</label>
                <input type="number" step="0.1" name="longueur" class="form-control" value="<%= article.longueur %>" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Largeur (cm)</label>
                <input type="number" step="0.1" name="largeur" class="form-control" value="<%= article.largeur %>" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Hauteur (cm)</label>
                <input type="number" step="0.1" name="hauteur" class="form-control" value="<%= article.hauteur %>" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Poids (kg)</label>
                <input type="number" step="0.1" name="poids" class="form-control" value="<%= article.poids %>" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Prix (DH)</label>
                <input type="number" step="0.01" name="prix" class="form-control" value="<%= article.prix %>" required>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-warning">Modifier</button>
                <a href="/articles" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</body>
</html>