<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Nouvel Emplacement</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Nouvel Emplacement</h2>
        <form action="/emplacements/create" method="POST" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Code</label>
                <input type="text" name="code" class="form-control" placeholder="E-001" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Zone</label>
                <select name="zoneId" class="form-select" required>
                    <% zones.forEach(z => { %>
                    <option value="<%= z.id %>"><%= z.code %> - <%= z.type %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Poids max (kg)</label>
                <input type="number" step="0.1" name="poidsMax" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Longueur (cm)</label>
                <input type="number" step="0.1" name="longueur" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Largeur (cm)</label>
                <input type="number" step="0.1" name="largeur" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Hauteur (cm)</label>
                <input type="number" step="0.1" name="hauteur" class="form-control" required>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Créer</button>
                <a href="/emplacements" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</body>
</html>