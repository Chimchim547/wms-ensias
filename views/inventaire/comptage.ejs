<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Comptage Physique</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Comptage Physique - Inventaire #<%= inventaire.id %></h2>
        <form action="/inventaire/comptage/<%= inventaire.id %>" method="POST">
            <table class="table">
                <thead class="table-dark">
                    <tr><th>Référence</th><th>Désignation</th><th>Qté théorique</th><th>Qté réelle</th><th>Justificatif</th></tr>
                </thead>
                <tbody>
                    <% inventaire.lignes.forEach(l => { %>
                    <tr>
                        <input type="hidden" name="ligneIds" value="<%= l.id %>">
                        <td><%= l.reference %></td>
                        <td><%= l.designation %></td>
                        <td><%= l.quantiteTheorique %></td>
                        <td><input type="number" name="quantitesReelles" class="form-control" value="<%= l.quantiteReelle %>" required></td>
                        <td><input type="text" name="justificatifs" class="form-control" value="<%= l.justificatif || '' %>" placeholder="Justificatif si écart"></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <button type="submit" class="btn btn-primary">Enregistrer le comptage</button>
            <a href="/inventaire" class="btn btn-secondary">Annuler</a>
        </form>
    </div>
</body>
</html>