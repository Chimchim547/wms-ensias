<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Transfert</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Déplacer un Article</h2>
        <form action="/mouvements/transfert" method="POST" class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Article à déplacer</label>
                <select name="articleId" class="form-select" required>
                    <% articles.forEach(a => { %>
                    <option value="<%= a.id %>"><%= a.reference %> - <%= a.designation %> (Actuel: <%= a.emplacement.code %> - Zone <%= a.emplacement.zone.code %>)</option>
                    <% }) %>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Nouvel emplacement</label>
                <select name="newEmplacementId" class="form-select" required>
                    <% emplacements.forEach(e => { %>
                    <option value="<%= e.id %>"><%= e.code %> - Zone <%= e.zone.code %></option>
                    <% }) %>
                </select>
            </div>
            <button type="submit" class="btn btn-secondary">Déplacer</button>
            <a href="/mouvements" class="btn btn-outline-secondary">Annuler</a>
        </form>
    </div>
</body>
</html>