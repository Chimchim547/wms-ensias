<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>WMS - Contrôle Qualité</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../layouts/navbar') %>
    <div class="container mt-4">
        <h2>Contrôle Qualité - Bon <%= bon.numero %></h2>
        <p>Fournisseur: <strong><%= bon.fournisseur.nom %></strong></p>
        <form action="/reception/controle/<%= bon.id %>" method="POST">
            <table class="table">
                <thead><tr><th>Article</th><th>Qté commandée</th><th>Qté reçue</th><th>Qté acceptée</th></tr></thead>
                <tbody>
                    <% bon.lignes.forEach(l => { %>
                    <tr>
                        <td><%= l.article.reference %> - <%= l.article.designation %></td>
                        <td><%= l.quantiteCommandee %></td>
                        <td><%= l.quantiteRecue %></td>
                        <td><input type="number" name="quantitesAcceptees" class="form-control" value="<%= l.quantiteRecue %>" max="<%= l.quantiteRecue %>"></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Résultat</label>
                    <select name="resultat" class="form-select" required>
                        <option value="conforme">Conforme</option>
                        <option value="partiellement_conforme">Partiellement conforme</option>
                        <option value="non_conforme">Non conforme</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <label class="form-label">Commentaire</label>
                    <input type="text" name="commentaire" class="form-control">
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-info">Valider le contrôle</button>
                <a href="/reception" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</body>
</html>